<!-- pages/profile/profile.wxml -->
<view class="container">
  <!-- 顶部背景区域 -->
  <view class="profile-header">
    <view class="header-bg"></view>
    <!-- 用户信息卡片 -->
    <view class="user-card" bindtap="login">
      <view class="avatar-wrapper">
        <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <view class="login-badge" wx:if="{{!userInfo.isLogin}}">
          <van-icon name="arrow" size="12px" color="#ffffff" />
        </view>
      </view>
      <view class="user-info">
        <view class="nickname">{{userInfo.nickName}}</view>
        <view class="login-tip" wx:if="{{!userInfo.isLogin}}">点击登录账号</view>
        <view class="edit-profile" wx:if="{{userInfo.isLogin}}" catchtap="editProfile">
          <van-icon name="edit" size="14px" color="#666666" style="margin-right: 4px;"/>
          <text>编辑资料</text>
        </view>
      </view>
    </view>
  </view>
  <!-- 个人数据统计 -->
  <view class="user-stats">
    <view class="stat-item" bindtap="onStatTap" data-type="read">
      <view class="stat-count">{{stats.readCount}}</view>
      <view class="stat-label">阅读数</view>
    </view>
    <view class="divider"></view>
    <view class="stat-item" bindtap="onStatTap" data-type="favorite">
      <view class="stat-count">{{stats.favoriteCount}}</view>
      <view class="stat-label">收藏数</view>
    </view>
    <view class="divider"></view>
    <view class="stat-item" bindtap="onStatTap" data-type="history">
      <view class="stat-count">{{stats.historyCount}}</view>
      <view class="stat-label">历史</view>
    </view>
  </view>
  <!-- 功能菜单区 -->
  <view class="section-title">我的服务</view>
  <view class="menu-list">
    <view wx:for="{{menuItems}}" wx:key="id" class="menu-item" bindtap="onMenuItemTap" data-id="{{item.id}}" hover-class="menu-item-hover">
      <view class="menu-icon-wrapper" style="color: {{item.id === 'notifications' ? '#1296db' : (item.id === 'edit_profile' ? '#3b82f6' : (item.id === 'settings' ? '#f59a23' : (item.id === 'help' ? '#8c6bf7' : '#1989fa')))}}">
        <van-icon name="{{item.icon}}" size="20px" />
      </view>
      <view class="menu-text">{{item.text}}</view>
      <van-icon name="arrow" class="menu-arrow" />
    </view>
  </view>
  <!-- 退出登录按钮 -->
  <block wx:if="{{userInfo.isLogin}}">
    <view class="logout-btn" bindtap="logout">
      <van-icon name="close" size="16px" color="#ff4d4f" style="margin-right: 6px;"/>
      退出登录
    </view>
  </block>
  <!-- 版本信息 -->
  <view class="version-info">
    <text>简讯速递 v1.0.0</text>
  </view>
</view>