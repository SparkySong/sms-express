<!--pages/settings/settings.wxml-->
<view class="container">
  <!-- 通用设置 -->
  <van-cell-group title="通用设置" custom-class="settings-group">
    <van-cell 
      title="深色模式"
      center
      label="{{settings.darkMode ? '已开启' : '已关闭'}}"
      size="large">
      <van-switch 
        checked="{{settings.darkMode}}" 
        bind:change="onDarkModeChange" 
        active-color="#1989fa"
        size="24px" />
    </van-cell>
    
    <van-cell 
      title="字体大小" 
      center
      size="large">
      <van-slider
        value="{{ settings.fontSize }}"
        step="1"
        min="12"
        max="20"
        active-color="#1989fa"
        bind:change="onFontSizeChange"
        custom-class="font-slider"
      />
    </van-cell>
    
    <van-cell 
      title="无图模式" 
      center
      label="减少流量消耗"
      size="large">
      <van-switch 
        checked="{{settings.noImageMode}}" 
        bind:change="onNoImageModeChange" 
        active-color="#1989fa"
        size="24px" />
    </van-cell>
    
    <van-cell 
      title="推送通知"
      center
      label="{{settings.pushNotification ? '已开启' : '已关闭'}}"
      size="large">
      <van-switch 
        checked="{{settings.pushNotification}}" 
        bind:change="onPushNotificationChange" 
        active-color="#1989fa"
        size="24px" />
    </van-cell>
  </van-cell-group>
  
  <!-- 关于与清理 -->
  <van-cell-group title="关于与清理" custom-class="settings-group">    
    <van-cell 
      title="清除缓存" 
      center
      value="{{cacheSize}}"
      size="large"
      is-link
      bind:click="clearCache" />
      
    <van-cell 
      title="当前版本" 
      value="V1.0.0"
      size="large" />
  </van-cell-group>
  
  <!-- 恢复默认设置 -->
  <view class="reset-btn-container">
    <van-button 
      type="danger" 
      custom-class="reset-btn"
      block
      bind:click="resetSettings">
      恢复默认设置
    </van-button>
  </view>
</view>

<!-- 对话框组件 -->
<van-dialog id="van-dialog" /> 