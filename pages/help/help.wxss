/* pages/help/help.wxss */
page {
  background-color: #f8f9fc;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 14px;
  color: #333;
}

.container {
  padding-bottom: 30px;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 标签切换样式 */
.tabs {
  display: flex;
  width: 100%;
  height: 44px;
  background-color: #fff;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 15px;
  color: #646566;
  position: relative;
}

.tab.active {
  color: #1989fa;
  font-weight: 500;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 20px;
  height: 3px;
  background-color: #1989fa;
  border-radius: 3px;
  transform: translateX(-50%);
}

/* 标签内容区域 */
.tab-content {
  padding: 16px;
}

/* FAQ样式 */
.faq-content {
  padding: 4px 0;
  color: #646566;
  line-height: 1.6;
}

.sub-info {
  margin-top: 8px;
  font-size: 13px;
  color: #969799;
}

.contact-item {
  margin-top: 8px;
  display: flex;
}

.contact-item .label {
  width: 80px;
  color: #969799;
}

.contact-item .value {
  color: #1989fa;
}

/* 联系我们区域 */
.contact-us {
  margin-top: 24px;
  padding: 16px;
  background-color: #fff;
  border-radius: 8px;
  text-align: center;
}

.contact-title {
  font-size: 14px;
  color: #646566;
  margin-bottom: 12px;
}

.feedback-btn {
  display: inline-block;
  color: #1989fa;
  font-size: 14px;
  font-weight: 500;
  padding: 6px 12px;
  background-color: #ecf5ff;
  border-radius: 16px;
}

/* 反馈表单样式 */
.feedback-form {
  background-color: #fff;
  border-radius: 8px;
  overflow: hidden;
}

.submit-btn-wrap {
  padding: 24px 16px;
}

.submit-btn {
  border-radius: 8px !important;
}

/* 反馈类型弹窗 */
.type-popup {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
}

.type-popup-mask {
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
}

.type-popup-content {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background-color: #fff;
  border-radius: 16px 16px 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.type-popup-title {
  text-align: center;
  font-size: 16px;
  font-weight: 500;
  padding: 16px 0;
  border-bottom: 1px solid #f5f5f5;
}

.type-options {
  max-height: 300px;
  overflow-y: auto;
}

.type-option {
  padding: 14px 16px;
  text-align: center;
  font-size: 14px;
  border-bottom: 1px solid #f5f5f5;
}

.type-option:active {
  background-color: #f5f5f5;
}

.type-popup-close {
  text-align: center;
  font-size: 16px;
  color: #646566;
  padding: 16px 0;
  border-top: 8px solid #f5f5f5;
}

/* 暗黑模式适配 */
@media (prefers-color-scheme: dark) {
  page {
    background-color: #1a1a1a;
    color: #f5f5f5;
  }
  
  .tabs {
    background-color: #2a2a2a;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }
  
  .tab {
    color: #aaa;
  }
  
  .faq-content {
    color: #bbb;
  }
  
  .contact-us {
    background-color: #2a2a2a;
  }
  
  .feedback-btn {
    background-color: #13233a;
  }
  
  .feedback-form {
    background-color: #2a2a2a;
  }
  
  .type-popup-content {
    background-color: #2a2a2a;
  }
  
  .type-popup-title {
    border-bottom-color: #333;
  }
  
  .type-option {
    border-bottom-color: #333;
  }
  
  .type-option:active {
    background-color: #333;
  }
  
  .type-popup-close {
    color: #aaa;
    border-top-color: #333;
  }
} 