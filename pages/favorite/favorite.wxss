/* pages/favorite/favorite.wxss */
.container {
  padding: 0 0 20px;
}

/* 顶部操作按钮 */
.top-action {
  display: flex;
  justify-content: flex-end;
  padding: 15px;
  background-color: #ffffff;
  border-bottom: 1px solid #f0f0f0;
}

.edit-btn {
  color: #3b82f6;
  font-size: 14px;
}

/* 批量操作栏 */
.batch-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 15px;
  background-color: #ffffff;
  border-bottom: 1px solid #f0f0f0;
}

.select-all {
  display: flex;
  align-items: center;
}

.action-buttons {
  display: flex;
  gap: 8px;
}

.clear-btn {
  margin-left: 10px;
}

/* 加载占位符 */
.loading-placeholder {
  padding: 15px;
  background-color: #ffffff;
}

/* 收藏列表 */
.favorite-list {
  background-color: #ffffff;
}

.favorite-item {
  display: flex;
  border-bottom: 1px solid #f0f0f0;
  position: relative;
}

.checkbox-wrapper {
  padding: 15px 10px 15px 15px;
  display: flex;
  align-items: center;
}

/* 新闻项样式 */
.news-item {
  flex: 1;
  display: flex;
  padding: 15px;
  position: relative;
}

.news-main {
  flex: 1;
  padding-right: 15px;
}

.news-tag-container {
  margin-bottom: 8px;
}

.news-tag {
  display: inline-block;
  font-size: 12px;
  color: #fff;
  background-color: #3b82f6;
  padding: 2px 6px;
  border-radius: 4px;
}

.news-title {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.news-info {
  font-size: 12px;
  color: #999;
  display: flex;
  align-items: center;
}

.news-source {
  max-width: 80px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.news-dot {
  margin: 0 4px;
}

.news-image-container {
  width: 100px;
  height: 70px;
  flex-shrink: 0;
  margin-left: auto;
  overflow: hidden;
  background-color: #f0f0f0;
  border-radius: 4px;
}

.news-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: 5px;
  top: 5px;
  padding: 5px;
  z-index: 10;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
}

/* 空状态 */
.empty-state {
  padding: 60px 0;
}

.bottom-button {
  margin: 16px auto 0;
}

/* 自定义复选框样式 */
.item-checkbox {
  display: flex;
  align-items: center;
}

/* 底部加载状态 */
.loading-status {
  text-align: center;
  padding: 16px 0;
  color: #999;
  font-size: 14px;
}

.no-more {
  color: #999;
}

/* 适配暗黑模式 */
@media (prefers-color-scheme: dark) {
  .container {
    background-color: #1a1a1a;
  }
  
  .top-action,
  .batch-actions,
  .favorite-list {
    background-color: #2a2a2a;
    border-color: #333;
  }
  
  .news-title {
    color: #f5f5f5;
  }
  
  .news-info {
    color: #888;
  }
  
  .no-more {
    color: #888;
  }
}