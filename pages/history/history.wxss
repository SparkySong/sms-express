/* pages/history/history.wxss */
page {
  background-color: #f7f8fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 14px;
  color: #333;
}

.container {
  padding: 0 0 20px;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 头部样式 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1px solid #ebedf0;
}

.title {
  font-size: 16px;
  font-weight: 500;
}

.actions {
  display: flex;
}

.action-btn {
  margin-left: 8px;
  height: 28px !important;
  padding: 0 10px !important;
}

.delete-btn {
  color: #fff !important;
  background-color: #ff4d4f !important;
  border-color: #ff4d4f !important;
}

/* 空状态 */
.empty-container {
  padding-top: 80px;
}

.go-read-btn {
  width: 160px !important;
  margin-top: 24px !important;
}

/* 历史列表 */
.history-list {
  padding: 0 16px;
}

.date-group {
  margin-bottom: 12px;
}

.history-items {
  background-color: #fff;
  border-radius: 8px;
  overflow: hidden;
  margin-top: 8px;
}

.history-item {
  display: flex;
  padding: 16px;
  border-bottom: 1px solid #f5f5f5;
  position: relative;
}

.history-item:last-child {
  border-bottom: none;
}

.edit-mode {
  background-color: #fff;
}

/* 选择框 */
.checkbox {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 1px solid #dcdee0;
  margin-right: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 24px;
}

.checkbox.checked {
  border-color: #1989fa;
  background-color: #fff;
}

/* 内容区 */
.item-content {
  display: flex;
  flex: 1;
}

.with-checkbox {
  margin-left: 8px;
}

.item-image {
  width: 100px;
  height: 68px;
  border-radius: 4px;
  flex-shrink: 0;
  margin-right: 12px;
  background-color: #f5f5f5;
}

.item-info {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-title {
  font-size: 15px;
  line-height: 1.4;
  margin-bottom: 8px;
  font-weight: 400;
  color: #323233;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  font-size: 12px;
  color: #969799;
  margin-top: auto;
}

.item-source {
  max-width: 120px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-dot {
  margin: 0 4px;
}

.category-tag {
  margin-left: 8px !important;
  font-size: 10px !important;
  padding: 0 4px !important;
  line-height: 16px !important;
  height: 16px !important;
}

/* 删除按钮 */
.delete-btn {
  width: 65px;
  height: 100%;
  background-color: #ee0a24;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 底部状态 */
.loading-more {
  text-align: center;
  padding: 16px 0;
}

.bottom-info {
  text-align: center;
  padding: 16px 0;
  color: #969799;
  font-size: 14px;
}

/* 适配暗黑模式 */
@media (prefers-color-scheme: dark) {
  page {
    background-color: #1a1a1a;
    color: #f5f5f5;
  }
  
  .header {
    background-color: #2a2a2a;
    border-bottom-color: #333;
  }
  
  .history-items {
    background-color: #2a2a2a;
  }
  
  .history-item {
    border-bottom-color: #333;
  }
  
  .checkbox {
    border-color: #555;
  }
  
  .item-title {
    color: #f5f5f5;
  }
  
  .item-meta {
    color: #aaa;
  }
} 