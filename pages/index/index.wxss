.container {
  padding: 0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  background-color: #f8f8f8;
  padding-bottom: 20px;
}

/* 头部样式 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 15px;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 1000;
}

.logo {
  font-size: 18px;
  font-weight: bold;
  color: #2c8df6;
}

/* 分类导航 */
.category-nav {
  display: flex;
  white-space: nowrap;
  background-color: #fff;
  padding: 10px 0;
  border-bottom: 1px solid #eee;
}

.category-item {
  display: inline-block;
  padding: 6px 18px;
  margin: 0 4px;
  font-size: 14px;
  border-radius: 18px;
}

.category-item:first-child {
  margin-left: 10px;
}

.category-item.active {
  background-color: #2c8df6;
  color: #fff;
}

/* 今日头条 */
.headline-section {
  background-color: #fff;
  padding-bottom: 15px;
  border-bottom: 10px solid #f0f0f0;
}

.section-title {
  font-size: 18px;
  font-weight: bold;
  padding: 15px;
}

/* 轮播图样式 */
.headline-swiper {
  height: 200px;
}

.headline-card {
  position: relative;
  margin: 0 15px;
  height: 200px;
  border-radius: 8px;
  overflow: hidden;
}

.headline-image {
  width: 100%;
  height: 100%;
}

.headline-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 15px;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
  color: #fff;
  z-index: 1;
}

.headline-title {
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 5px;
}

.headline-desc {
  font-size: 14px;
  opacity: 0.9;
}

/* 自定义轮播点样式 */
.wx-swiper-dots {
  position: relative;
  bottom: 10px !important;
}

.wx-swiper-dot {
  width: 8rpx;
  height: 8rpx;
  margin-left: 6rpx;
  margin-right: 6rpx;
}

.wx-swiper-dot-active {
  width: 16rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #1989fa !important;
}

/* 最新资讯 */
.news-section {
  background-color: #fff;
}

.news-list {
  background-color: #fff;
}

.news-item {
  position: relative;
  display: flex;
  flex-direction: column;
  padding: 15px;
  border-bottom: 1px solid #f0f0f0;
}

.news-content {
  flex: 1;
  margin-bottom: 10px;
}

.news-title {
  font-size: 16px;
  font-weight: 500;
  margin-bottom: 8px;
  line-height: 1.4;
  padding-right: 130px;
}

.news-info {
  font-size: 12px;
  color: #999;
  margin-bottom: 8px;
}

.news-source,
.news-time,
.news-reads {
  display: inline-block;
}

.news-dot {
  margin: 0 5px;
  display: inline-block;
}

.news-image {
  position: absolute !important;
  right: 15px !important;
  top: 15px !important;
}

.news-actions {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  margin-top: 10px;
}

.action-item {
  display: flex;
  align-items: center;
  margin-right: 20px;
}

.action-icon {
  margin-right: 2px;
  color: #666;
  display: flex;
  align-items: center;
}

.action-count, .action-text {
  font-size: 12px;
  color: #666;
}

/* 自定义Vant组件样式 */
.van-tabs__line {
  background-color: #1989fa !important;
}

.van-tab--active {
  color: #1989fa !important;
  font-weight: bold;
}

/* 适配图片中的布局 */
@media screen and (min-width: 375px) {
  .news-item {
    min-height: 80px;
  }
}

/* 空数据状态 */
.empty-data {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 200px;
  width: 100%;
  color: #999;
}

.empty-data text {
  margin-top: 10px;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 15px 0;
  color: #999;
  font-size: 14px;
}


