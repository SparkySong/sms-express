

/* 头部导航栏 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background-color: #ffffff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.08);
}

.header-left {
  font-size: 30rpx;
  color: #666666;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  transition: all 0.3s;
}

.header-left:active {
  background-color: #f2f3f5;
}

.header-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.header-right {
  font-size: 30rpx;
  color: #3b82f6;
  font-weight: 500;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  transition: all 0.3s;
}

.header-right:active {
  background-color: rgba(59, 130, 246, 0.1);
}

.header-right.disabled {
  color: #cccccc;
  pointer-events: none;
}

/* 加载中提示 */
.loading-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
  margin-top: 200rpx;
}

/* 编辑表单 */
.edit-form {
  margin: 30rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid #f2f3f5;
  transition: background-color 0.3s;
}

.form-item:active {
  background-color: #f9f9f9;
}

.form-item:last-child {
  border-bottom: none;
}

.item-label {
  width: 180rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.item-input {
  flex: 1;
  height: 44rpx;
  font-size: 30rpx;
  color: #333333;
  padding: 8rpx 0;
}

.item-value {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.readonly {
  color: #999999;
}

.item-arrow {
  color: #cccccc;
  margin-left: 16rpx;
}

.item-picker {
  flex: 1;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
  color: #333333;
}

/* 头像项样式 */
.avatar-item {
  padding: 40rpx 36rpx;
}

.avatar-wrapper {
  position: relative;
  margin-right: 20rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  background-color: #f5f5f5;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s;
}

.avatar:active {
  transform: scale(0.96);
}

.change-avatar {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background-color: #3b82f6;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.4);
  border: 3rpx solid #ffffff;
}

/* 头像上传进度 */
.upload-progress-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.65);
  border-radius: 70rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.progress-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.progress-bar-bg {
  width: 70%;
  height: 8rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background-color: #3b82f6;
  border-radius: 4rpx;
  transition: width 0.3s ease-out;
}

/* 文本域表单项 */
.form-item-block {
  padding: 32rpx 36rpx;
  border-bottom: 1rpx solid #f2f3f5;
}

.item-textarea {
  width: 100%;
  height: 240rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  background-color: #f9fafc;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333333;
  box-sizing: border-box;
  border: 1rpx solid #ebedf0;
  transition: all 0.3s;
}

.item-textarea:focus {
  border-color: #d0d9ff;
  background-color: #ffffff;
  box-shadow: 0 0 0 2rpx rgba(59, 130, 246, 0.1);
}

.textarea-counter {
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 16rpx;
}

/* 底部提示 */
.bottom-tips {
  text-align: center;
  font-size: 26rpx;
  color: #999999;
  margin: 60rpx 30rpx 30rpx;
  padding: 20rpx;
  background-color: #f9fafc;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 提交按钮 */
.submit-btn-wrapper {
  padding: 0 30rpx;
  margin-top: 60rpx;
  margin-bottom: 80rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4c8cf6, #3b82f6);
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(59, 130, 246, 0.3);
  transition: all 0.3s;
  border: none;
  outline: none;
}

.submit-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 8rpx rgba(59, 130, 246, 0.3);
}

.submit-btn.disabled {
  opacity: 0.6;
  background: linear-gradient(135deg, #b3c7e6, #a5c0f0);
  box-shadow: none;
}

/* 按钮通用悬停效果 */
.button-hover {
  opacity: 0.8;
} 